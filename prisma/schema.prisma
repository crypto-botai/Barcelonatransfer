generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  DRIVER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DriverStatus {
  PENDING_APPROVAL
  APPROVED
  SUSPENDED
  OFFLINE
  ONLINE
  ON_RIDE
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  TRANSFERRED
}

enum WithdrawalMethod {
  BANK
  BIZUM
}

enum VehicleClass {
  ECONOMY
  BUSINESS
  LUXURY
  FIRST_CLASS
  ELECTRIC_VIP
  SUV
  LUXURY_SUV
  MINIVAN
  LUXURY_MINIVAN
  MINIBUS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  bookings        Booking[]
  driver          Driver?
  customerProfile CustomerProfile?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Driver {
  id              String       @id @default(cuid())
  userId          String       @unique
  status          DriverStatus @default(PENDING_APPROVAL)
  licenseNumber   String?
  licenseExpiry   DateTime?
  taxiLicense     String?
  taxiLicenseExp  DateTime?
  nationalId      String?
  bio             String?      @db.Text
  rating          Float        @default(0)
  totalRides      Int          @default(0)
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  whatsappNumber    String?
  licenseFileUrl    String?
  vehiclePermitUrl  String?
  vehiclePhotoFront String?
  vehiclePhotoBack  String?
  insuranceUrl      String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles    Vehicle[]
  bookings    Booking[]
  withdrawals Withdrawal[]

  @@map("drivers")
}

model Vehicle {
  id           String       @id @default(cuid())
  driverId     String?
  class        VehicleClass
  make         String
  model        String
  year         Int
  color        String
  licensePlate String
  maxPassengers Int
  maxLuggage   Int
  features     String[]
  imageUrl     String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  driver   Driver?   @relation(fields: [driverId], references: [id])
  bookings Booking[]

  @@map("vehicles")
}

model PricingRule {
  id              String       @id @default(cuid())
  vehicleClass    VehicleClass
  baseFare        Float
  pricePerKm      Float
  pricePerMinute  Float
  minimumFare     Float
  airportSurcharge Float       @default(10)
  nightSurcharge  Float        @default(0.25)
  nightStartHour  Int          @default(22)
  nightEndHour    Int          @default(6)
  isActive        Boolean      @default(true)
  updatedAt       DateTime     @updatedAt

  @@unique([vehicleClass])
  @@map("pricing_rules")
}

model Booking {
  id              String        @id @default(cuid())
  userId          String?
  driverId        String?
  vehicleId       String?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  pickupAddress   String
  pickupLat       Float
  pickupLng       Float
  dropoffAddress  String
  dropoffLat      Float
  dropoffLng      Float
  pickupDatetime  DateTime
  passengers      Int           @default(1)
  luggage         Int           @default(0)
  vehicleClass    VehicleClass
  flightNumber    String?
  specialRequests String?       @db.Text
  driverAmount    Float?
  adminNotes      String?       @db.Text
  distanceKm      Float         @default(0)
  durationMin     Int           @default(0)
  baseFare        Float
  distanceFare    Float         @default(0)
  airportSurcharge Float        @default(0)
  nightSurcharge  Float         @default(0)
  totalAmount     Float
  currency        String        @default("EUR")
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  stripeSessionId String?
  stripePaymentId String?
  confirmationCode String       @unique @default(cuid())
  driverAssignedAt DateTime?
  rideStartedAt   DateTime?
  rideEndedAt     DateTime?
  rating          Int?
  review          String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User?      @relation(fields: [userId], references: [id])
  driver   Driver?    @relation(fields: [driverId], references: [id])
  vehicle  Vehicle?   @relation(fields: [vehicleId], references: [id])
  tracking RideTracking[]
  payment  Payment?

  @@map("bookings")
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  stripePaymentId String?
  stripeSessionId String?
  amount          Float
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  receiptUrl      String?
  refundId        String?
  refundAmount    Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model RideTracking {
  id        String   @id @default(cuid())
  bookingId String
  lat       Float
  lng       Float
  speed     Float?
  heading   Float?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("ride_tracking")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  type      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Withdrawal {
  id         String           @id @default(cuid())
  driverId   String
  amount     Float
  method     WithdrawalMethod
  bankIban   String?
  bankName   String?
  bizumPhone String?
  status     WithdrawalStatus @default(PENDING)
  notes      String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

// ─── CRM & Operations Models ─────────────────────────────────

model CustomerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  isVip         Boolean  @default(false)
  isBlacklisted Boolean  @default(false)
  vipSince      DateTime?
  notes         String?  @db.Text
  totalSpent    Float    @default(0)
  totalRides    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  adminName String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([adminId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Marketing & Automation Models ──────────────────────────

model BookingSession {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  email        String?
  name         String?
  phone        String?
  formData     Json
  step         Int      @default(1)
  lastActivity DateTime @default(now())
  converted    Boolean  @default(false)
  createdAt    DateTime @default(now())

  abandonedBooking AbandonedBooking?

  @@index([email])
  @@index([lastActivity])
  @@map("booking_sessions")
}

model AbandonedBooking {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  email       String
  name        String?
  phone       String?
  formSnapshot Json
  couponId    String?   @unique
  emailSentAt DateTime?
  convertedAt DateTime?
  createdAt   DateTime  @default(now())

  session BookingSession @relation(fields: [sessionId], references: [sessionId])
  coupon  Coupon?        @relation(fields: [couponId], references: [id])

  @@index([email])
  @@index([createdAt])
  @@map("abandoned_bookings")
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  email       String?
  discountPct Float     @default(5)
  discountAmt Float?
  usedAt      DateTime?
  expiresAt   DateTime
  isActive    Boolean   @default(true)
  bookingId   String?
  createdAt   DateTime  @default(now())

  abandonedBooking AbandonedBooking?

  @@index([code])
  @@index([email])
  @@index([expiresAt])
  @@map("coupons")
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  isActive       Boolean   @default(true)
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  source         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
  @@index([isActive])
  @@map("newsletter_subscribers")
}

model EmailCampaign {
  id          String    @id @default(cuid())
  subject     String
  htmlBody    String    @db.Text
  status      String    @default("DRAFT")
  sentAt      DateTime?
  scheduledAt DateTime?
  targetCount Int       @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs EmailLog[]

  @@map("email_campaigns")
}

model EmailLog {
  id         String    @id @default(cuid())
  to         String
  subject    String
  type       String
  status     String    @default("SENT")
  resendId   String?
  campaignId String?
  bookingId  String?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())

  campaign EmailCampaign? @relation(fields: [campaignId], references: [id])

  @@index([to])
  @@index([type])
  @@index([createdAt])
  @@map("email_logs")
}

# ═══════════════════════════════════════════════════════════════
# ÉLITE BCN TRANSFERS — Environment Variables
# Copy this file to .env.local for local development.
# Set production values in: Vercel → Project → Settings → Env Vars
# ═══════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ─────────────────────────
# Get from: Supabase → Project → Settings → Database → Connection String
# Use "Transaction mode" (port 6543) with ?pgbouncer=true for DATABASE_URL
# Use "Session mode"     (port 5432) for DIRECT_URL (migrations only)
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@db.XXXX.supabase.co:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
# Production URL — no trailing slash
NEXTAUTH_URL="https://barcelonatransfer-gsj6.vercel.app"

# ─── Google OAuth (optional — social login) ─────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── SumUp Payment Gateway ───────────────────────────────────
#
# HOW TO GET YOUR SUMUP CREDENTIALS:
# ─────────────────────────────────
# 1. Create/log into your SumUp merchant account at https://sumup.com
# 2. Go to: Dashboard → Developers → API Keys
# 3. Click "Create API Key" → this is your SUMUP_API_KEY
#    Format: sup_sk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# 4. Find your Merchant Code:
#    Dashboard → Account Settings → Merchant Profile → Merchant Code
#    Format: MXXXXXXXX  (starts with M, 8 characters total)
#
# NOTE: The booking system works WITHOUT SumUp configured —
#       bookings will be saved and customers redirected to WhatsApp payment.
#       Configure SumUp to enable automated online payments.
#
SUMUP_API_KEY="sup_sk_your_sumup_api_key_here"
SUMUP_MERCHANT_CODE="MXXXXXXXX"

# SumUp Webhook Secret (recommended for production):
# ─────────────────────────────────────────────────
# 1. Go to: SumUp Dashboard → Developers → Webhooks
# 2. Click "Create Webhook"
# 3. Endpoint URL: https://barcelonatransfer-gsj6.vercel.app/api/payments/webhook
# 4. Events to subscribe: checkout.paid, checkout.failed
# 5. Copy the generated secret and paste below
SUMUP_WEBHOOK_SECRET="your_sumup_webhook_secret"

# SumUp Test Mode:
# ─────────────────────────────────────────────────
# Use sandbox credentials from: https://developer.sumup.com/docs/development-tools/sandbox/
# Test card number: 4000 0000 0000 0002  (any future date, any CVV)
# Live mode: replace the key with your production sup_sk_LIVE_... key

# ─── Google Maps API (optional) ─────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIzaSy..."

# ─── Resend (transactional email) ────────────────────────────
# Get from: https://resend.com → API Keys
# Verify your sending domain in: Resend → Domains
RESEND_API_KEY="re_your_resend_api_key"

# Admin email — receives new booking notifications
ADMIN_EMAIL="vtcbcn2025@gmail.com"

# ─── Company Contact ─────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="34635383712"
NEXT_PUBLIC_PHONE="+34 635 383 712"
NEXT_PUBLIC_EMAIL="vtcbcn2025@gmail.com"

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST (Vercel Environment Variables)
# ═══════════════════════════════════════════════════════════════
# ✓ DATABASE_URL
# ✓ DIRECT_URL
# ✓ NEXTAUTH_SECRET
# ✓ NEXTAUTH_URL
# ✓ SUMUP_API_KEY           ← required for online payments
# ✓ SUMUP_MERCHANT_CODE     ← required for online payments
# ✓ SUMUP_WEBHOOK_SECRET    ← required for auto-confirmation
# ✓ RESEND_API_KEY          ← required for confirmation emails
# ✓ ADMIN_EMAIL
# Optional:
# ✓ GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET  (social login)
# ✓ NEXT_PUBLIC_GOOGLE_MAPS_KEY              (address autocomplete)
# ═══════════════════════════════════════════════════════════════
